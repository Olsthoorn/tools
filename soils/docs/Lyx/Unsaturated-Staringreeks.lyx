\begin_body

\begin_layout Title
Onverzadigde zone - Staringreeks
\end_layout

\begin_layout Author
T.N.Olsthoorn
\end_layout

\begin_layout Date
24-03-2026
\end_layout

\begin_layout Abstract
Voor de modules Soils (Kinematic Wave en Munsflow) heb ik alle bodems van de Staringreeks gemodelleerd volgens Heinen,
 Bakker en Wösen (2018@@) samen met de US-soil volgens Charbeneau (2000).
 Ik heb ze allemaal geïmplemeneerd in python en in jupyter notebooks.
 Ik ben ze afleidingen alleen kwijtgeraakt.
 In dit document probeer ik dat weer zo goed mogelijk te herstellen.
\end_layout

\begin_layout Section
Introductie
\end_layout

\begin_layout Standard
De waterretentiekarakteristiek volgens Van Genughten (1980) en de waterdoorlatendheidskarakteristiek volgens Mualem (1976) zijn geformuleerd door 6 parameters:
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\boxed{\theta_{r},\theta_{s},\alpha,n,\lambda,K_{s};\;NB:m=1-1/n}
\]

\end_inset


\end_layout

\begin_layout Standard
Waarin:
\end_layout

\begin_layout Description
\begin_inset Formula $\theta$
\end_inset

 [-] volumetrisch watergehalte
\end_layout

\begin_layout Description
\begin_inset Formula $\theta_{r}$
\end_inset

 [-] residueel volumetrisch watergehalte (
\begin_inset Formula $\theta$
\end_inset

 vooor 
\begin_inset Formula $h\to\infty$
\end_inset

)
\end_layout

\begin_layout Description
\begin_inset Formula $\theta_{s}$
\end_inset

 [-] Volumetrisch watergehalte bij verzadiging
\end_layout

\begin_layout Description
\begin_inset Formula $\alpha$
\end_inset

 [cm
\begin_inset Formula $^{-1}$
\end_inset

]vormparameter
\end_layout

\begin_layout Description
\begin_inset Formula $\lambda$
\end_inset

 [-] vormparameter
\end_layout

\begin_layout Description
\begin_inset Formula $n,m$
\end_inset

 [-] vormparameters
\end_layout

\begin_layout Description
\begin_inset Formula $h$
\end_inset

 [cm] drukhoogte 
\begin_inset Formula $\left(\phi=z\right)$
\end_inset


\end_layout

\begin_layout Description
\begin_inset Formula $\phi$
\end_inset

 [ m] zuigspanning 
\begin_inset Formula $\left(-h\right)$
\end_inset


\end_layout

\begin_layout Description
\begin_inset Formula $K$
\end_inset

 [cm/d] hydraulische doorlatendheid
\end_layout

\begin_layout Description
\begin_inset Formula $K_{s}$
\end_inset

 [cm/d] hydraulische doorlatendheid bij verzadiging
\end_layout

\begin_layout Description
\begin_inset Formula $S$
\end_inset

 [-] Verzadiging 
\begin_inset Formula $\frac{\theta-\theta_{r}}{\theta_{s}-\theta_{r}}$
\end_inset

 Dit wordt 
\begin_inset Quotes pld
\end_inset

reduced satuartion genoemd door Charbeneau (2000,
 p196)
\end_layout

\begin_layout Description
\begin_inset Formula $z$
\end_inset

 [m] afstand tot het grondwater,
 naar beneden positief.
\end_layout

\begin_layout Description
\begin_inset Formula $q$
\end_inset

 [cm/d] neerwaartse fluxdichtheid
\end_layout

\begin_layout Standard
De waterretentiekaraketeristiek volgens Van Genughten (1980):
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{equation}
S\left(\theta\right)=\frac{\theta-\theta_{r}}{\theta_{s}-\theta_{r}}=\left(\frac{1}{1+\left|\alpha h\right|^{n}}\right)^{m}\label{eq:wateretentiekar-vG80}
\end{equation}

\end_inset


\end_layout

\begin_layout Standard
De waterdoorlatendheidskarateristiek volgens Mualem (1976;
 zie ook Van Genughten (1980) onder de voorwaarde dat 
\begin_inset Formula $m=1-1/n$
\end_inset

 is
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{equation}
K\left(h\right)=K_{s}\frac{\left(\left(1+\left|\alpha h\right|^{n}\right)^{m}-\left|\alpha h\right|^{n-1}\right)^{2}}{\left(1+\left|\alpha h^{n}\right|\right)^{m\left(\lambda+2\right)}}\label{eq:doorlatendheidskarMuelem76}
\end{equation}

\end_inset


\end_layout

\begin_layout Standard
In (
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:wateretentiekar-vG80"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

) en (
\begin_inset CommandInset ref
LatexCommand ref
reference "eq:doorlatendheidskarMuelem76"
plural "false"
caps "false"
noprefix "false"
nolink "false"

\end_inset

) mag 
\begin_inset Formula $h$
\end_inset

 door 
\begin_inset Formula $\psi$
\end_inset

 worden vervangen.
 Ik werk liever met 
\begin_inset Formula $\psi$
\end_inset

 omdat 
\begin_inset Formula $\phi>0$
\end_inset

 in de onverzadigde zone.
\end_layout

\begin_layout Section
Richards vergelijking
\end_layout

\begin_layout Standard
De Richards vergelijking stuurt de verticale onverzadigde stroming.
 Verondersteld wordt dat de stroming volledig verticaal is.
\end_layout

\begin_layout Standard
De Richards-vergelijking voor onverzadigde stroming volgt uit een combinatie van continuïteit en de wet van Darcy.
 Continuïteit vergt
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\frac{\partial\theta}{\partial t}=-\frac{\partial q}{\partial z}
\]

\end_inset


\end_layout

\begin_layout Standard
Darcy
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
q=-K\frac{\partial\phi}{\partial z}
\]

\end_inset


\end_layout

\begin_layout Standard
Hierin is 
\family roman
\series medium
\shape up
\size normal
\emph off
\nospellcheck off
\bar no
\strikeout off
\xout off
\uuline off
\uwave off
\noun off
\color none
de stijghoogte 
\begin_inset Formula $\phi=\zeta+h,$
\end_inset

met 
\begin_inset Formula $h$
\end_inset

 de drukhoogte en 
\begin_inset Formula $\zeta$
\end_inset

 de hoogte boven een referentieniveau.
 De afstand 
\begin_inset Formula $z$
\end_inset

 beneden de basis van de wortelzone op niveau 
\begin_inset Formula $\zeta_{0}$
\end_inset

 is dan 
\begin_inset Formula $z=\zeta_{0}-\zeta$
\end_inset

 zodat
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
q & =-K\frac{\partial}{\partial z}\left(\zeta_{0}-z+h\right)\\
 & =K\left(-\frac{\partial h}{\partial z}+1\right)
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
Met 
\begin_inset Formula $h=-\psi$
\end_inset

 met 
\begin_inset Formula $\psi$
\end_inset

 de zuigspanning in dezelfde eenheden als 
\begin_inset Formula $h$
\end_inset

 krijgen we
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
q=K\left(\frac{\partial\psi}{\partial z}+1\right)
\]

\end_inset


\end_layout

\begin_layout Standard
De differentiaalvergelijking combineert de continuïteit met de flux tot de Richards-vergelijking:
\begin_inset Formula 
\begin{equation}
\frac{\partial\theta}{\partial t}=-\frac{\partial}{\partial z}\left[K\left(\frac{\partial\psi}{\partial z}+1\right)\right]\label{eq:Rechargds-verg-1}
\end{equation}

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\frac{\partial\theta}{\partial t}=\frac{\partial}{\partial z}\left[-K\frac{\partial\psi}{\partial z}-K\right]
\]

\end_inset


\end_layout

\begin_layout Standard
Omschrijven naar een vergelijking met 
\begin_inset Formula $\theta$
\end_inset

 als enige afhankelijke variabele
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\frac{\partial\theta}{\partial t}=\frac{\partial}{\partial z}\left[-K-K\frac{\partial\psi}{\partial\theta}\frac{\partial\theta}{\partial z}\right]
\]

\end_inset


\end_layout

\begin_layout Standard
met
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
S=-\frac{d\theta}{d\psi}
\]

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\frac{\partial\theta}{\partial t}=\frac{\partial}{\partial z}\left[-K+\frac{K}{S}\frac{\partial\theta}{\partial z}\right]
\]

\end_inset


\end_layout

\begin_layout Standard
In munsflow wordt 
\begin_inset Formula $D=K/S$
\end_inset

 constant genomen wat leidt tot
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\frac{\partial\theta}{\partial t}=-K\frac{\partial\theta}{\partial z}+D\frac{\partial^{2}\theta}{\partial z^{2}}
\]

\end_inset


\end_layout

\begin_layout Section
Kinematic Wave
\end_layout

\begin_layout Standard
De benadering Voor de kinematic wave is het weglaten van de capillaire spanning uit de Richardsvergelijking
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
\frac{\partial\theta}{\partial t} & =-\frac{\partial K}{\partial z}\\
 & =-\frac{dK}{d\theta}\frac{\partial\theta}{\partial z}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
Schrijf dit als
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
0=\frac{\partial\theta}{\partial t}+\frac{\partial\theta}{\partial z}\frac{dK}{d\theta}
\]

\end_inset


\end_layout

\begin_layout Standard
Vergelijk met totale potentiaal
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
d\theta=\frac{\partial\theta}{\partial t}dt+\frac{\partial\theta}{\partial z}dz
\]

\end_inset


\end_layout

\begin_layout Standard
Deze zijn gelijk wanneer
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
0=\frac{1}{dt}+\frac{1}{dz}\frac{dK}{d\theta}
\]

\end_inset


\end_layout

\begin_layout Standard
Wat leidt tot
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\frac{dz}{dt}=V=-\frac{dK}{d\theta}
\]

\end_inset


\end_layout

