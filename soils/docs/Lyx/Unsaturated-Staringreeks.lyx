\end_layout

\begin_layout Standard
Verzadiging of reduced moisture content 
\begin_inset Formula $S$
\end_inset

.
 Charbeneau (2000) gebruikt een hoofdletter 
\begin_inset Formula $\Theta$
\end_inset

 maar die is niet goed te onderscheiden van 
\begin_inset Formula $\theta$
\end_inset

.
 Vandaar dat hier 
\begin_inset Formula $S$
\end_inset

 wordt gebruikt.
 
\begin_inset Formula $S$
\end_inset

 is de belangrijkste parameter en alle relaties worden ook uitgedrukt als functie van 
\begin_inset Formula $S$
\end_inset

.
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
S\left(\theta\right)=\frac{\theta-\theta_{r}}{\theta_{s}-\theta_{r}}
\]

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\theta\left(S\right)=\theta_{r}+\left(\theta_{s}-\theta_{r}\right)S
\]

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\frac{\partial S}{\partial\theta}=\frac{\theta}{\theta_{s}-\theta_{r}}
\]

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\frac{\partial\theta}{\partial S}=\theta_{s}-\theta_{r}
\]

\end_inset


\end_layout

\begin_layout Standard
Saturatie 
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
Sat\left(\theta\right)=\frac{\theta}{\theta_{S}}
\]

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
Sat\left(S\right)=Sat\left(\theta\left(S\right)\right)
\]

\end_inset


\end_layout

\begin_layout Standard
Mualem Van Genughten (zie Heinen,
 Bakker en Wösten),
 afhankelijkheid van de zuigspanning 
\begin_inset Formula $\psi$
\end_inset

:
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
S\left(\theta\right)=\frac{\theta-\theta_{r}}{\theta_{s}-\theta_{r}}=\left(\frac{1}{1+\left(\alpha\psi\right)^{n}}\right)^{m}
\]

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
S\left(\psi\right)=\left(\frac{1}{1+\left(\alpha\psi\right)^{n}}\right)^{m}=\left(1+\left(\alpha\psi\right)^{n}\right)^{-m}
\]

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\frac{\partial S}{\partial\psi}=-\alpha mn\left(1+\left(\alpha\psi\right)^{n}\right)^{-1-m}\left(\alpha\psi\right)^{n-1}
\]

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\psi\left(S\right)=\frac{1}{\alpha}\left(S^{-1/m}-1\right)^{1/n}
\]

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\frac{\partial\psi}{\partial S}=\frac{-1}{\alpha nm}\left(S^{-1/m}-1\right)^{-1+1/n}S^{-1-1/m}
\]

\end_inset


\end_layout

\begin_layout Standard
Doorlatendheid (Heinen,
 Bakker en Wösten (2020):
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
K\left(\psi\right)=K_{s}\frac{\left(\left(1+\left(\alpha\psi\right)^{n}\right)^{m}-\left(\alpha\psi\right)^{n-1}\right)^{2}}{\left(1+\left(\alpha\psi\right)^{n}\right)^{m\left(\lambda+2\right)}}
\]

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
S=\left(1+\left(\alpha\psi\right)^{n}\right)^{-m}
\]

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
S^{-1/m} & =1+\left(\alpha\psi\right)^{n}\\
\left(\alpha\psi\right)^{n} & =S^{-1/m}-1
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
\left(\alpha\psi\right)^{n-1} & =\left(\left(S^{-1/m}-1\right)^{1/n}\right)^{n-1}\\
 & =\left(S^{-1/m}-1\right)^{1-1/n}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
K\left(\psi\right)=K_{s}S^{\lambda+2}\left(S^{-1}-\left(S^{-1/m}-1\right)^{1-1/n}\right)^{2}
\]

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
K_{HBW}\left(S\right) & =K_{s}S^{\lambda+2}\left(S^{-1}-\left(S^{-1/m}-1\right)^{1-1/n}\right)^{2}.
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
\frac{\partial K_{HBW}\left(S\right)}{\partial S} & =...\\
A & =S^{-1}-\left(S^{-1/m}-1\right)^{1-1/n}\\
\frac{\partial A}{\partial S} & =-S^{-2}-\left(1-\frac{1}{n}\right)\left(S^{-1/m}-1\right)^{-1/n}\times\frac{-1}{m}S^{-1-1/m}\\
\frac{\partial K_{HBW}}{\partial S} & =K_{s}\left(\left(\lambda+2\right)S^{\lambda+1}A^{2}+2S^{\lambda+2}A\frac{\partial A}{\partial S}\right)
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\]

\end_inset


\end_layout

\begin_layout Standard
Relaties die direct volgen uit de voorgaande
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\frac{d\theta\left(\psi\right)}{d\psi}=\frac{d\theta}{dS}\frac{dS\left(\psi\right)}{d\psi}
\]

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\frac{d\psi}{d\theta}=\frac{d\psi}{dS}\frac{dS\left(\theta\right)}{d\theta}
\]

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\psi\left(\theta\right)=\psi\left(S\left(\theta\right)\right)
\]

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\theta\left(\psi\right)=\theta\left(S\left(\psi\right)\right)
\]

\end_inset


\end_layout

\begin_layout Standard
Vochtcapaciteit
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
C\left(S\right)=-\frac{d\theta\left(\psi\left(S\right)\right)}{d\psi}
\]

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
C\left(\psi\right)=-\frac{d\theta\left(\psi\right)}{d\psi}
\]

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
C\left(\theta\right)=-\frac{d\theta\left(\psi\left(\theta\right)\right)}{d\psi}
\]

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
D\left(S\right)=\frac{K\left(S\right)}{C\left(S\right)}
\]

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
D\left(\psi\right)=D\left(S\left(\psi\right)\right)
\]

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
D\left(\theta\right)=D\left(S\left(\theta\right)\right)
\]

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
K\left(\theta\right)=K\left(S\left(\theta\right)\right)
\]

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\frac{\partial K}{\partial\theta}=\frac{\partial K\left(S\left(\theta\right)\right)}{\partial S}\frac{\partial S\left(\theta\right)}{\partial\theta}
\]

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
K\left(\psi\right)=K\left(S\left(\psi\right)\right)
\]

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\frac{\partial K}{\partial\psi}=\frac{\partial K\left(S\left(\psi\right)\right)}{\partial S}\frac{\partial S\left(\psi\right)}{\partial\psi}
\]

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
K_{vGM}\left(S\right) & =K_{s}S^{l}\left(1-\left(\left(1-S\right)^{1/m}\right)^{m}\right)^{2}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
\frac{\partial K_{vGM}}{\partial S} & =...\\
B & =1-\left(\left(1-S\right)^{1/m}\right)^{m}\\
\frac{\partial B}{\partial S} & =\left(1-S^{1/m}\right)^{m-1}S^{-1+1/m}\\
\frac{\partial K_{vGM}}{\partial S} & =K_{s}lS^{l-1}B^{2}+2S^{l}B\frac{\partial B}{\partial S}
\end{align*}

\end_inset


\begin_inset Newline newline
\end_inset


\begin_inset Formula 
\begin{align*}
K_{HBW}\left(S\right) & =K_{s}S^{\lambda+2}\left(S^{-1}-\left(S^{-1/m}-1\right)^{1-1/n}\right)^{2}.
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
\frac{\partial K_{HBW}\left(S\right)}{\partial S} & =...\\
A & =S^{-1}-\left(S^{-1/m}-1\right)^{1-1/n}\\
\frac{\partial A}{\partial S} & =-S^{-2}-\left(1-\frac{1}{n}\right)\left(S^{-1/m}-1\right)^{-1/n}\times\frac{-1}{m}S^{-1-1/m}\\
\frac{\partial K_{HBW}}{\partial S} & =K_{s}\left(\left(\lambda+2\right)S^{\lambda+1}A^{2}+2S^{\lambda+2}A\frac{\partial A}{\partial S}\right)
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
De 
\begin_inset Formula $K$
\end_inset

 is een van de twee,
 afhankelijk van de keuze vGM (Van Genughten Mualem (1980,
 1976) of Heinen,
 Bakker Wösten (2020).
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
K\left(S\right)=K_{vGM}\left(S\right)|K_{HBW}\left(S\right)
\]

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\frac{\partial K}{\partial S}=\frac{\partial K_{vGM}\left(S\right)}{\partial S}|\frac{\partial K_{HBW}\left(S\right)}{\partial S}
\]

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula $S\left(K\right)$
\end_inset

 Moet worden berekend middels een interpolator.
 Genereer eerst de interpolator als functie van 
\begin_inset Formula $S$
\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
s=\text{logspace}\left(-8,0\right)
\]

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
k=K\left(s\right)
\]

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
s_{lnk}=\text{PchipInterpolator}\left(\ln\left(k\right),s\right)
\]

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\text{S}\left(k\right)=s_{lnk}\left(\ln\left(k\right)\right)
\]

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula $\theta\left(V\right)$
\end_inset

 wordt ook via interpolator berekend 
\begin_inset Formula $V=\frac{\partial K\left(\theta\right)}{\partial\theta}$
\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
s=\text{logspace}\left(-8,0,100\right)
\]

\end_inset


\begin_inset Formula 
\[
\theta=\theta\left(S\right)
\]

\end_inset


\begin_inset Newline newline
\end_inset


\begin_inset Formula 
\[
V=\frac{\partial K\left(\theta\right)}{\partial\theta}
\]

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\text{lnVinterp}=\text{PchipInterpolator\left(\ln V,\theta\right)}
\]

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\theta\left(V\right)=\text{lnVinterp\left(\ln\left(V\right)\right)}
\]

\end_inset


\end_layout

\begin_layout Standard
=====
\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\theta\left(K\right)=\theta\left(S\left(K\right)\right)
\]

\end_inset


\end_layout

\begin_layout Standard
Snelheid 
\begin_inset Formula $v$
\end_inset

 en diffusiviteit 
\begin_inset Formula $D$
\end_inset

 benodigd voor Munsflow.
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
vD\left(q\right) & =...\\
S & =S\left(K\left(k_{0}\right)\right)\\
v & =\frac{\partial K\left(S\right)}{\partial\theta}\\
D & =D\left(S\right)\\
... & =\left(v,D\right)
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
Vochtpunt snelheid
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
V & =\frac{\partial K\left(\theta\right)}{\partial\theta}
\end{align*}

\end_inset


\end_layout

\begin_layout Standard
\begin_inset Formula 
\[
\frac{dz_{f}}{dt}=\frac{K\left(\theta_{1}\right)-K\left(\theta_{2}\right)}{\theta_{1}-\theta_{2}}
\]

\end_inset


\end_layout

\begin_layout Standard
Verticale snelheid van het water
\end_layout

\begin_layout Standard
\begin_inset Formula 
\begin{align*}
q_{z} & =K\left(\theta\right)\\
v_{z} & =\frac{K\left(\theta\right)}{\theta}
\end{align*}

\end_inset


\end_layout

