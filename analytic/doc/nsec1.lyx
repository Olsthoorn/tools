\begin_layout Plain Layout

class Nsec1():
\end_layout

\begin_layout Plain Layout

    """Class to analytically simulate stead state flow in a linked leaky aquifer.
\end_layout

\begin_layout Plain Layout

    The 1D single layer aquifer consits of sections of length L[i].
\end_layout

\begin_layout Plain Layout

    Each section has its now vertical resistance and its own transmissivity.
\end_layout

\begin_layout Plain Layout

    At each connection point a flow Q may be injected.
\end_layout

\begin_layout Plain Layout

    At both outer boundaries a head or a flow may be specified.
\end_layout

\begin_layout Plain Layout

    Afterwords the head and flow along all sections can can be simulated.
\end_layout

\begin_layout Plain Layout

    
\end_layout

\begin_layout Plain Layout

    Simplified version of nsecn made in 2000.
\end_layout

\begin_layout Plain Layout

    
\end_layout

\begin_layout Plain Layout

    @ TO 2026-0610
\end_layout

\begin_layout Plain Layout

    """
\end_layout

\begin_layout Plain Layout

    
\end_layout

\begin_layout Plain Layout

    def __init__(self,
 kD=None,
 c=None,
 L=None,
 X0=0.0,
 Np=51):
\end_layout

\begin_layout Plain Layout

        self.kD = np.array(kD,
 dtype=float)
\end_layout

\begin_layout Plain Layout

        self.c  = np.array( c,
 dtype=float)
\end_layout

\begin_layout Plain Layout

        self.L  = np.array( L,
 dtype=float)        
\end_layout

\begin_layout Plain Layout

        if not all(np.array([len(kD),
 len(c),
 len(L)]) == len(kD)):
\end_layout

\begin_layout Plain Layout

            raise ValueError("1D vectors kD,
 c and L must all have the same length.")
\end_layout

\begin_layout Plain Layout

        self.X0 = X0
\end_layout

\begin_layout Plain Layout

        self.Np = Np
\end_layout

\begin_layout Plain Layout

        
\end_layout

\begin_layout Plain Layout

    @property
\end_layout

\begin_layout Plain Layout

    def X(self):
\end_layout

\begin_layout Plain Layout

        """Return section end points as array."""
\end_layout

\begin_layout Plain Layout

        return self.X0 + np.hstack((0,
 np.cumsum(self.L)))
\end_layout

\begin_layout Plain Layout

        
\end_layout

\begin_layout Plain Layout

        
\end_layout

\begin_layout Plain Layout

    @property
\end_layout

\begin_layout Plain Layout

    def x(self):
\end_layout

\begin_layout Plain Layout

        """Return x coordinates spanning the entire area.
\end_layout

\begin_layout Plain Layout

        
\end_layout

\begin_layout Plain Layout

        You may inject the number of points per section by
\end_layout

\begin_layout Plain Layout

        injectiong the variable Np into the instantiated class.
\end_layout

\begin_layout Plain Layout

        
\end_layout

\begin_layout Plain Layout

        mdl = Nsec1(...)
\end_layout

\begin_layout Plain Layout

        mdl.Np = 51
\end_layout

\begin_layout Plain Layout

        
\end_layout

\begin_layout Plain Layout

        """
\end_layout

\begin_layout Plain Layout

        x = np.array([self.X[0]],
 dtype=float)
\end_layout

\begin_layout Plain Layout

        for x1,
 x2 in zip(self.X[:-1],
 self.X[1:]):
\end_layout

\begin_layout Plain Layout

            x = np.hstack((x,
 np.linspace(x1,
 x2,
 self.Np)[1:]))
\end_layout

\begin_layout Plain Layout

        return x
\end_layout

\begin_layout Plain Layout

        
\end_layout

\begin_layout Plain Layout

    @property
\end_layout

\begin_layout Plain Layout

    def Nsec(self):
\end_layout

\begin_layout Plain Layout

        """Return number of sections."""
\end_layout

\begin_layout Plain Layout

        return len(self.kD)
\end_layout

\begin_layout Plain Layout

        
\end_layout

\begin_layout Plain Layout

    @property
\end_layout

\begin_layout Plain Layout

    def lam(self):
\end_layout

\begin_layout Plain Layout

        """Return spreading lengths."""
\end_layout

\begin_layout Plain Layout

        return np.sqrt(self.kD * self.c)
\end_layout

\begin_layout Plain Layout

    
\end_layout

\begin_layout Plain Layout

    # --- Matrix coordinates kernel (submatrix)
\end_layout

\begin_layout Plain Layout

    def coefsAB(self,
 i):
\end_layout

\begin_layout Plain Layout

        """Return 2x4 kernel coefficient matrix truncated to 2x2 at both outer nodes.
\end_layout

\begin_layout Plain Layout

        
\end_layout

\begin_layout Plain Layout

        Note 0 is the left node of section 0
\end_layout

\begin_layout Plain Layout

        
\end_layout

\begin_layout Plain Layout

        """
\end_layout

\begin_layout Plain Layout

        N = len(self.kD)
\end_layout

\begin_layout Plain Layout

        
\end_layout

\begin_layout Plain Layout

        eL = 0 if i<0   else np.exp(-self.L[i-1] / self.lam[i-1])
\end_layout

\begin_layout Plain Layout

        eR = 0 if i>= N else np.exp(-self.L[i]   / self.lam[i])
\end_layout

\begin_layout Plain Layout

        
\end_layout

\begin_layout Plain Layout

        fL = 0 if i<0  else self.kD[i-1] / self.lam[i-1]
\end_layout

\begin_layout Plain Layout

        fR = 0 if i>=N else self.kD[i]   / self.lam[i]
\end_layout

\begin_layout Plain Layout

        
\end_layout

\begin_layout Plain Layout

        M = np.array([
\end_layout

\begin_layout Plain Layout

            [     eL,
   1,
  -1,
     -eR],
\end_layout

\begin_layout Plain Layout

            [fL * eL,
 -fL,
 -fR,
 fR * eR],
\end_layout

\begin_layout Plain Layout

        ],
 dtype=float)
\end_layout

\begin_layout Plain Layout

        if i == 0:
\end_layout

\begin_layout Plain Layout

            M = M[:,
 2:]
\end_layout

\begin_layout Plain Layout

        if i == N:
\end_layout

\begin_layout Plain Layout

            M = M[:,
 :2]
\end_layout

\begin_layout Plain Layout

        return M
\end_layout

\begin_layout Plain Layout

\end_layout

\begin_layout Plain Layout

    @property
\end_layout

\begin_layout Plain Layout

    def coefMat(self):
\end_layout

\begin_layout Plain Layout

        """Return coefficient matrix."""
\end_layout

\begin_layout Plain Layout

        N = len(self.kD)
\end_layout

\begin_layout Plain Layout

        A = np.zeros((2*(N + 1),
 2*N))
\end_layout

\begin_layout Plain Layout

        for i in range(N + 1):
\end_layout

\begin_layout Plain Layout

            M = self.coefsAB(i)            
\end_layout

\begin_layout Plain Layout

            
\end_layout

\begin_layout Plain Layout

            j0 = max(0,
 2 * (i - 1))
\end_layout

\begin_layout Plain Layout

            j1 = min(2 * N,
 j0 + M.shape[1])
\end_layout

\begin_layout Plain Layout

                
\end_layout

\begin_layout Plain Layout

            A[2*i:2*i+2,
 j0:j1] = M
\end_layout

\begin_layout Plain Layout

        return A
\end_layout

\begin_layout Plain Layout

    
\end_layout

\begin_layout Plain Layout

    def set_boundaries(self,
 Phi=None,
 Q=None):
\end_layout

\begin_layout Plain Layout

        # --- Boundary conditions
\end_layout

\begin_layout Plain Layout

        RHS = np.zeros(2*(self.Nsec + 1))
\end_layout

\begin_layout Plain Layout

        h = np.hstack((Phi[0],
 self.h,
 Phi[-1]))
\end_layout

\begin_layout Plain Layout

        RHS[::2] = + h[1:] - h[:-1]
\end_layout

\begin_layout Plain Layout

        RHS[1::2] = Q
\end_layout

\begin_layout Plain Layout

        
\end_layout

\begin_layout Plain Layout

        # --- Make Q equation or Phi equation at left and right inactive depending boundary type.
\end_layout

\begin_layout Plain Layout

        active = np.ones(2 * (self.Nsec + 1),
 dtype=bool)
\end_layout

\begin_layout Plain Layout

        
\end_layout

\begin_layout Plain Layout

        if not np.isnan(Phi[0]):
\end_layout

\begin_layout Plain Layout

            # --- Phi is given at left end
\end_layout

\begin_layout Plain Layout

            # --- Q equation is inactive
\end_layout

\begin_layout Plain Layout

            # RHS[0] = -Phi[0]
\end_layout

\begin_layout Plain Layout

            active[0] = True
\end_layout

\begin_layout Plain Layout

            active[1] = False
\end_layout

\begin_layout Plain Layout

        else:
\end_layout

\begin_layout Plain Layout

            # --- Q is given at left end
\end_layout

\begin_layout Plain Layout

            # --- Phi equation is inactive
\end_layout

\begin_layout Plain Layout

            active[0] = False
\end_layout

\begin_layout Plain Layout

            active[1] = True    
\end_layout

\begin_layout Plain Layout

            
\end_layout

\begin_layout Plain Layout

        if not np.isnan(Phi[-1]):
\end_layout

\begin_layout Plain Layout

            # --- Phi is given at right end
\end_layout

\begin_layout Plain Layout

            # --- Q equation inactive
\end_layout

\begin_layout Plain Layout

            # RHS[-2] = Phi[-1]
\end_layout

\begin_layout Plain Layout

            active[-2] = True
\end_layout

\begin_layout Plain Layout

            active[-1] = False
\end_layout

\begin_layout Plain Layout

        else:
\end_layout

\begin_layout Plain Layout

            # --- Q given at right end
\end_layout

\begin_layout Plain Layout

            # --- Phi-equation inactive    
\end_layout

\begin_layout Plain Layout

            active[-2] = False
\end_layout

\begin_layout Plain Layout

            active[-1] = True
\end_layout

\begin_layout Plain Layout

        return RHS,
 active
\end_layout

\begin_layout Plain Layout

\end_layout

\begin_layout Plain Layout

\end_layout

\begin_layout Plain Layout

    def simulate(self,
 Phi=None,
 Q=None,
 h=None,
 x=None,
 Np=51):
\end_layout

\begin_layout Plain Layout

        """Return heads and flow given the boundaries.
\end_layout

\begin_layout Plain Layout

        
\end_layout

\begin_layout Plain Layout

        Parameters
\end_layout

\begin_layout Plain Layout

        ----------
\end_layout

\begin_layout Plain Layout

        Phi:
 sequence of 2
\end_layout

\begin_layout Plain Layout

            Heads at left and righ boundary.
 Use np.nan to use Q as boundary.
\end_layout

\begin_layout Plain Layout

        Q:
 None | sequence of 2 or sequence of Nsec + 1 (numer of Nodes)
\end_layout

\begin_layout Plain Layout

            Flow boundary conditions.
 None to use zeros,
 seq.
 of 2 to use these
\end_layout

\begin_layout Plain Layout

            at either end and 0 for intermediate points.
 Use squence of Nsec + 1 
\end_layout

\begin_layout Plain Layout

            to specify Q at all intermediate points.
\end_layout

\begin_layout Plain Layout

            Specificagion of Phi determines wheather the edge Q values will be used.
\end_layout

\begin_layout Plain Layout

        h:
 sequence of float (Nsec)
\end_layout

\begin_layout Plain Layout

            Adjacent head in each section ("polder level")
\end_layout

\begin_layout Plain Layout

        x:
 None or seqence of increasing x-coordinates
\end_layout

\begin_layout Plain Layout

           None will span x between self.X with Np points per section
\end_layout

\begin_layout Plain Layout

        Np:
 int
\end_layout

\begin_layout Plain Layout

           Number of coordinates per sectioin if x is None
\end_layout

\begin_layout Plain Layout

           You may inject it into the instantiated class:
\end_layout

\begin_layout Plain Layout

           
\end_layout

\begin_layout Plain Layout

           mdl = Nsec1(...)
\end_layout

\begin_layout Plain Layout

           mdl.Np = 51
\end_layout

\begin_layout Plain Layout

           
\end_layout

\begin_layout Plain Layout

        """
\end_layout

\begin_layout Plain Layout

        self.Np = Np
\end_layout

\begin_layout Plain Layout

        
\end_layout

\begin_layout Plain Layout

        if h is None:
\end_layout

\begin_layout Plain Layout

            self.h = np.zeros(self.Nsec)
\end_layout

\begin_layout Plain Layout

        else:
\end_layout

\begin_layout Plain Layout

            self.h = np.array(h,
 dtype=float)
\end_layout

\begin_layout Plain Layout

            if len(self.h) != self.Nsec:
\end_layout

\begin_layout Plain Layout

                raise ValueError(f"Number of heads must equal number of sections {self.Nsec}")
\end_layout

\begin_layout Plain Layout

        
\end_layout

\begin_layout Plain Layout

        # --- Boundary Q and injection at connection points
\end_layout

\begin_layout Plain Layout

        if Q is None:
\end_layout

\begin_layout Plain Layout

            Q = np.zeros(self.Nsec + 1)
\end_layout

\begin_layout Plain Layout

        else:
\end_layout

\begin_layout Plain Layout

            Q = np.array(Q,
 dtype=float)
\end_layout

\begin_layout Plain Layout

            assert len(Q) == 2 or len(Q) == self.Nsec + 1,
 f"Q must have length 2 or {self.Nsec + 1} or be None."
\end_layout

\begin_layout Plain Layout

\end_layout

\begin_layout Plain Layout

        # --- Coordinates for plotting        
\end_layout

\begin_layout Plain Layout

        if x is None:
\end_layout

\begin_layout Plain Layout

            x = self.x
\end_layout

\begin_layout Plain Layout

        
\end_layout

\begin_layout Plain Layout

        # --- Coefficient matrix
\end_layout

\begin_layout Plain Layout

        A = self.coefMat
\end_layout

\begin_layout Plain Layout

        
\end_layout

\begin_layout Plain Layout

        # --- RHS
\end_layout

\begin_layout Plain Layout

        RHS,
 active = self.set_boundaries(Phi=Phi,
 Q=Q)
\end_layout

\begin_layout Plain Layout

        
\end_layout

\begin_layout Plain Layout

        # --- Solve for coefficients
\end_layout

\begin_layout Plain Layout

        coefs = np.linalg.solve(A[active],
 RHS[active])
\end_layout

\begin_layout Plain Layout

        
\end_layout

\begin_layout Plain Layout

        # --- Compute heads and flows for all x
\end_layout

\begin_layout Plain Layout

        phi,
 Qx = self.get_phi_Q(coefs,
 x)
\end_layout

\begin_layout Plain Layout

        
\end_layout

\begin_layout Plain Layout

        return {'phi':
 phi,
 'Qx':Qx}        
\end_layout

\begin_layout Plain Layout

\end_layout

\begin_layout Plain Layout

    def get_phi_Q(self,
 coefs,
 x):
\end_layout

\begin_layout Plain Layout

        """Return heads and flows."""
\end_layout

\begin_layout Plain Layout

        CA,
 CB = coefs[0::2],
 coefs[1::2]
\end_layout

\begin_layout Plain Layout

        
\end_layout

\begin_layout Plain Layout

        # --- Initialize heads and flows
\end_layout

\begin_layout Plain Layout

        phi = np.zeros_like(x,
 dtype=float)
\end_layout

\begin_layout Plain Layout

        Q   = np.zeros_like(x,
 dtype=float)
\end_layout

\begin_layout Plain Layout

        
\end_layout

\begin_layout Plain Layout

        # --- For each section compute heads and flows
\end_layout

\begin_layout Plain Layout

        for i in range(self.Nsec):
\end_layout

\begin_layout Plain Layout

            mask = (x >= self.X[i]) & (x <= self.X[i+1])
\end_layout

\begin_layout Plain Layout

            eL = np.exp(-(x[mask] - self.X[i  ]) / self.lam[i])
\end_layout

\begin_layout Plain Layout

            eR = np.exp(-(self.X[i+1] - x[mask]) / self.lam[i])    
\end_layout

\begin_layout Plain Layout

            phi[mask] = CA[i] * eL + CB[i] * eR + self.h[i]
\end_layout

\begin_layout Plain Layout

            Q[ mask]  = self.kD[i] / self.lam[i] * (CA[i] * eL - CB[i] * eR)
\end_layout

\begin_layout Plain Layout

        return phi,
 Q
\end_layout

